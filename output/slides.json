{
  "plan": {
    "deck_title": "Sistema Web Unobtainium — Plataforma Full-Stack de Orçamentos",
    "brief": "Apresentação final do projeto da disciplina CC6PDSW. Sistema web full-stack com Next.js + Fastify, evoluído com melhorias de segurança e um módulo completo de orçamentos comerciais com máquina de estados e regras de negócio.",
    "audience": "Professor e banca avaliadora da disciplina CC6PDSW",
    "objective": "Demonstrar a evolução técnica do projeto: da base CRUD inicial às melhorias de produção (erros centralizados, rate limiting, autorização RBAC, paginação) e ao módulo de propostas com regras de negócio complexas",
    "slides": [
      {
        "slide_number": 0,
        "story_role": "opening",
        "archetype_id": "title_slide",
        "action_title": "Sistema Web Unobtainium"
      },
      {
        "slide_number": 1,
        "story_role": "conclusion",
        "archetype_id": "executive_summary",
        "action_title": "O projeto evoluiu de um CRUD básico para uma plataforma profissional com 5 melhorias de produção e um módulo completo de orçamentos com máquina de estados",
        "key_points": [
          "Arquitetura em camadas: Fastify + Prisma + Next.js 14",
          "5 melhorias: erros centralizados, rate limiting, autorização RBAC, paginação, normalização de email",
          "Módulo de orçamentos: 3 novos modelos, máquina de estados, cálculos server-side, relatórios gerenciais",
          "11 slides a seguir demonstrando arquitetura, melhorias e o módulo principal"
        ],
        "visual_hint": "Resumo executivo com os 3 pilares do projeto lado a lado"
      },
      {
        "slide_number": 2,
        "story_role": "section",
        "archetype_id": "section_divider",
        "action_title": "Arquitetura do Sistema"
      },
      {
        "slide_number": 3,
        "story_role": "supporting_argument",
        "archetype_id": "two_column",
        "action_title": "A arquitetura separa frontend Next.js do backend Fastify, comunicando-se via API REST com autenticação JWT em cookie httpOnly",
        "key_points": [
          "Frontend: Next.js 14 App Router + shadcn/ui (base-nova) + React Hook Form + Zod",
          "Backend: Fastify 4 + Prisma 5 + SQLite + JWT + bcrypt",
          "Autenticação: middleware Next.js protege /dashboard, backend valida JWT em cookie",
          "8 modelos: User, Service, Contact, Project, Testimonial, Proposal, ProposalItem, ProposalHistory"
        ],
        "visual_hint": "Duas colunas: esquerda = frontend stack, direita = backend stack"
      },
      {
        "slide_number": 4,
        "story_role": "section",
        "archetype_id": "section_divider",
        "action_title": "5 Melhorias de Produção"
      },
      {
        "slide_number": 5,
        "story_role": "supporting_argument",
        "archetype_id": "three_column",
        "action_title": "Tratamento centralizado de erros, rate limiting e autorização RBAC transformaram a robustez da API",
        "key_points": [
          "Erros centralizados: 6 classes (AppError → ValidationError, NotFoundError, UnauthorizedError, ForbiddenError, RateLimitError) com handler global Fastify",
          "Rate limiting: 5 tentativas por IP em 15 min no login, bloqueio com HTTP 429, limpeza periódica de memória",
          "Autorização RBAC: campo role no User (admin/user), middleware requireAdmin, self-or-admin para edição de perfil"
        ],
        "visual_hint": "Três cartões lado a lado, um para cada melhoria, com ícones e descrições"
      },
      {
        "slide_number": 6,
        "story_role": "evidence",
        "archetype_id": "three_column",
        "action_title": "Paginação, ordenação, busca textual e normalização de email completam as melhorias de qualidade de dados",
        "key_points": [
          "Paginação: helper padronizado (?page, limit, sort, order, search) aplicado a todos os 5 endpoints de listagem; resposta { data, total, page, limit, totalPages }",
          "Busca textual: filtro contains nos campos principais de cada entidade (título, nome, email, descrição)",
          "Normalização: emails em contatos e propostas são normalizados (trim + lowercase) antes do salvamento"
        ],
        "visual_hint": "Três cartões com exemplos de query params e resposta"
      },
      {
        "slide_number": 7,
        "story_role": "section",
        "archetype_id": "section_divider",
        "action_title": "Módulo de Orçamentos e Propostas"
      },
      {
        "slide_number": 8,
        "story_role": "supporting_argument",
        "archetype_id": "content_bullets",
        "action_title": "O módulo de propostas implementa uma máquina de estados com 5 status, validações de transição e cálculos exclusivamente server-side",
        "key_points": [
          "Máquina de estados: draft → sent → accepted/rejected/expired — apenas transições válidas são permitidas",
          "Cálculo server-side: unitPrice lido do Service, subtotal = quantity × unitPrice, total = subtotal − discount",
          "Regras de bloqueio: propostas enviadas têm itens e desconto congelados; apenas status pode ser alterado após envio",
          "Histórico completo: toda mudança de status, alteração de item e ajuste de desconto é registrada com userId e timestamp"
        ],
        "visual_hint": "Fluxo da máquina de estados com bullets explicativos abaixo"
      },
      {
        "slide_number": 9,
        "story_role": "evidence",
        "archetype_id": "three_column",
        "action_title": "Três novos modelos sustentam o módulo: Proposal, ProposalItem e ProposalHistory",
        "key_points": [
          "Proposal: título, cliente, subtotal, desconto (0 ≤ desc ≤ subtotal), total, status, notas — 11 endpoints REST",
          "ProposalItem: serviço referenciado, quantidade, unitPrice (snapshot do Service.price), subtotal calculado — cascade delete",
          "ProposalHistory: registro de auditoria com campo alterado, valor antigo, valor novo, usuário e timestamp — ordenado por data"
        ],
        "visual_hint": "Três cartões com o nome do modelo e campos principais"
      },
      {
        "slide_number": 10,
        "story_role": "evidence",
        "archetype_id": "big_number",
        "action_title": "Expiração automática de propostas enviadas há mais de 7 dias garante consistência sem intervenção manual",
        "key_points": [
          "60 segundos: intervalo da rotina de verificação no server.ts",
          "7 dias: prazo para propostas com status 'sent' serem marcadas como 'expired'",
          "0 dependências externas: cron implementado com setInterval nativo, sem bibliotecas adicionais"
        ],
        "visual_hint": "Número grande com contexto explicativo"
      },
      {
        "slide_number": 11,
        "story_role": "supporting_argument",
        "archetype_id": "icon_grid",
        "action_title": "O dashboard de orçamentos oferece relatórios gerenciais, CRUD completo e visualização detalhada com histórico de alterações",
        "key_points": [
          "Relatórios: total de propostas, aceitas, receita acumulada e taxa de conversão em cards coloridos",
          "Criação de proposta: seleção múltipla de serviços com quantidade, cálculo de total em tempo real, desconto configurável",
          "Ações contextuais: botões Enviar/Aceitar/Recusar aparecem conforme o status atual da proposta",
          "Visualização detalhada: itens com preços, subtotais e histórico completo de alterações por usuário"
        ],
        "visual_hint": "Grade de ícones representando cada funcionalidade do dashboard"
      },
      {
        "slide_number": 12,
        "story_role": "closing",
        "archetype_id": "big_statement",
        "action_title": "O projeto demonstra domínio de arquitetura em camadas, regras de negócio complexas, controle de estados e processos automatizados — conceitos centrais da disciplina"
      },
      {
        "slide_number": 13,
        "story_role": "closing",
        "archetype_id": "end_slide",
        "action_title": "Obrigado"
      }
    ]
  },
